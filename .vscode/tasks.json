{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake: 配置",
            "type": "shell",
            "command": "cmake",
            "args": [".."],
            "options": {
                "cwd": "${workspaceFolder}/build"
            },
            "problemMatcher": [],
            "group": "build"
        },
        {
            "label": "Make: 编译 MICOAIR405V2",
            "type": "shell",
            "command": "make",
            "args": ["MICOAIR405V2"],    // 直接写目标名，不再用 TARGET=[citation:8]
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "options": {
                "cwd": "${workspaceFolder}/build"
            },
            "problemMatcher": ["$gcc"]
        }
    ]
}